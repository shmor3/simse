# ============================================================================
# simse deployment secrets
# Copy to .env and fill in values, then run ./deployment/setup.sh
# ============================================================================

# --- GitHub Actions ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Secrets Store ---
# Create at: https://dash.cloudflare.com > Workers & Pages > Secrets Store
# Used by simse-api and simse-mailer
SECRETS_STORE_ID_PRODUCTION=
SECRETS_STORE_ID_STAGING=

# --- simse-payments (wrangler secrets) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
API_SECRET=
MAILER_API_URL=
MAILER_API_SECRET=

# --- Staging Stripe (optional, use different keys for staging) ---
STRIPE_SECRET_KEY_STAGING=
STRIPE_WEBHOOK_SECRET_STAGING=
API_SECRET_STAGING=
MAILER_API_URL_STAGING=
MAILER_API_SECRET_STAGING=
